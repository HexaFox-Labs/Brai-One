GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=3201
LOG_LEVEL=info
NATS_SERVERS=nats://brai-nats:4222
NATS_USER=
NATS_PASSWORD=
NATS_INBOX_PREFIX=_INBOX.brai.gateway
NATS_REQUEST_TIMEOUT_MS=30000
PUBLIC_ORIGINS=https://factory.brai.one
ALLOW_LOOPBACK_HOSTS=true
ACCESS_API_ENABLED=false
SUPABASE_AUTH_ISSUER=https://auth.example.test
SUPABASE_AUTH_JWKS_URL=https://auth.example.test/.well-known/jwks.json
SUPABASE_AUTH_AUDIENCE=authenticated
PLATFORM_ADMIN_HEADER_SECRET=replace-with-server-only-32-byte-minimum-secret
PLATFORM_ADMIN_ACTOR_ID=00000000-0000-4000-8000-000000000000
