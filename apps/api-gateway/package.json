{
  "name": "@brai/api-gateway",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.22.3 <23"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/main.ts",
    "lint": "eslint src test vitest.config.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@brai/contracts": "workspace:*",
    "@brai/nats": "workspace:*",
    "@brai/runtime": "workspace:*",
    "@fastify/rate-limit": "11.1.0",
    "fastify": "5.10.0",
    "jose": "6.2.3",
    "pino": "10.3.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "tsx": "4.23.1"
  }
}
