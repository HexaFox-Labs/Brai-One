# Non-secret runtime host configuration. NATS password and signing key material
# are systemd credentials, never EnvironmentFile values.
BRAI_RUNTIME_NATS_SERVERS=nats://127.0.0.1:4222
BRAI_RUNTIME_NATS_USER=brai-runtime-host
BRAI_RUNTIME_LAUNCH_KEY_ID=access-launch-2026-07
BRAI_RUNTIME_RECEIPT_KEY_ID=runtime-host-2026-07
BRAI_RUNTIME_REGISTRY_ROOT=/var/lib/brai-agent-runtime/developer-runs
