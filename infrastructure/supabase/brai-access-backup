#!/usr/bin/env bash

set -euo pipefail

readonly backup_program=${BRAI_SHARED_BACKUP_PROGRAM:-/srv/opt/brai-db-telegram-backup.sh}
readonly postgres_container=${BRAI_POSTGRES_CONTAINER:-supabase-db}
readonly postgres_database=${BRAI_POSTGRES_DATABASE:-postgres}
readonly postgres_user=${BRAI_POSTGRES_USER:-postgres}

fail() {
  echo "brai-access backup wrapper: $*" >&2
  exit 1
}

if [[ ${EUID} -ne 0 ]]; then
  fail "must run as root through brai-db-telegram-backup.service"
fi
if [[ ! -f ${backup_program} || -L ${backup_program} || ! -x ${backup_program} ]]; then
  fail "shared backup program is not a regular executable file"
fi

backup_owner=$(stat --format='%u:%g' "${backup_program}")
backup_mode=$(stat --format='%a' "${backup_program}")
if [[ ${backup_owner} != "0:0" || $((8#${backup_mode} & 8#022)) -ne 0 ]]; then
  fail "shared backup program must be root-owned and non-writable"
fi

schema_output=$(
  docker exec "${postgres_container}" \
    psql \
    -U "${postgres_user}" \
    -d "${postgres_database}" \
    --no-psqlrc \
    --tuples-only \
    --no-align \
    --command="SELECT nspname FROM pg_namespace ORDER BY nspname"
)

declare -A existing_schemas=()
while IFS= read -r schema; do
  schema=${schema//[[:space:]]/}
  if [[ -n ${schema} ]]; then
    existing_schemas["${schema}"]=1
  fi
done <<<"${schema_output}"

for schema in ${BRAI_REQUIRED_BACKUP_SCHEMAS:-}; do
  if [[ ! ${schema} =~ ^[a-z_][a-z0-9_]*$ ]]; then
    fail "invalid required schema name"
  fi
  if [[ -z ${existing_schemas[${schema}]:-} ]]; then
    fail "required schema is absent: ${schema}"
  fi
done

filtered_schemas=()
for schema in ${BRAI_BACKUP_SCHEMAS:-}; do
  if [[ ! ${schema} =~ ^[a-z_][a-z0-9_]*$ ]]; then
    fail "invalid configured schema name"
  fi
  if [[ -n ${existing_schemas[${schema}]:-} ]]; then
    filtered_schemas+=("${schema}")
  fi
done
if [[ ${#filtered_schemas[@]} -eq 0 ]]; then
  fail "none of the configured schemas exists"
fi

export BRAI_BACKUP_SCHEMAS="${filtered_schemas[*]}"
# The shared legacy backup helper has an optional project status hook. The
# access wrapper is host-owned and must never execute code from a checkout.
unset BRAI_DATABASE_URL
exec "${backup_program}"
