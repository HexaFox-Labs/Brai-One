{
  "name": "@brai/integration-tests",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.22.3 <23"
  },
  "scripts": {
    "lint": "eslint test vitest.config.ts",
    "test": "NODE_ENV=test vitest run --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@brai/api-gateway": "workspace:*",
    "@brai/brai-factory": "workspace:*",
    "@brai/contracts": "workspace:*",
    "@brai/nats": "workspace:*",
    "@brai/runtime": "workspace:*",
    "@brai/supabase-migrations": "workspace:*",
    "pg": "8.16.3",
    "pino": "10.3.1"
  },
  "devDependencies": {
    "@nats-io/nats-core": "3.4.0",
    "@types/node": "22.20.1",
    "@types/pg": "8.15.5",
    "testcontainers": "12.0.4",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "4.1.8"
  },
  "nx": {
    "targets": {
      "test": {
        "cache": false,
        "dependsOn": [
          "^build"
        ]
      },
      "typecheck": {
        "dependsOn": [
          "^build"
        ]
      }
    }
  }
}
